local function MakeHeader(text, order)
    local f = Instance.new("Frame")
    f.Parent               = Scroll
    f.Size                 = UDim2.new(1, 0, 0, 20)
    f.BackgroundTransparency = 1
    f.LayoutOrder          = order
    f.ZIndex               = 6
    local lbl = Instance.new("TextLabel")
    lbl.Parent               = f
    lbl.Size                 = UDim2.new(1, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Font                 = Enum.Font.GothamBold
    lbl.Text                 = "— " .. text .. " —"
    lbl.TextColor3           = Color3.fromRGB(0, 220, 130)
    lbl.TextSize             = 11
    lbl.TextXAlignment       = Enum.TextXAlignment.Center
    lbl.ZIndex               = 7
    return f
end

local LabelMap = {}
local function MakeRow(key, default, order, isSub)
    local f = Instance.new("Frame")
    f.Parent               = Scroll
    f.Size                 = UDim2.new(1, 0, 0, 18)
    f.BackgroundTransparency = 1
    f.LayoutOrder          = order
    f.ZIndex               = 6
    local lbl = Instance.new("TextLabel")
    lbl.Parent               = f
    lbl.Size                 = UDim2.new(1, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Font                 = Enum.Font.Gotham
    lbl.TextXAlignment       = Enum.TextXAlignment.Left
    lbl.TextSize             = 11
    lbl.RichText             = true
    lbl.ZIndex               = 7
    local prefix = isSub
        and "  <font color='#80ffb0'>· " .. key .. ":</font> "
        or  "<font color='#aaaaaa'>" .. key .. ":</font> "
    lbl.Text = prefix .. "<font color='#ffffff'>" .. default .. "</font>"
    LabelMap[key] = { lbl = lbl, prefix = prefix }
    return f
end

