-- Hàm tạo label section header
local function CreateHeader(text, order)
    local f = Instance.new("Frame")
    f.Parent = ScrollFrame
    f.Size = UDim2.new(1, 0, 0, 24)
    f.BackgroundTransparency = 1
    f.LayoutOrder = order

    local left = Instance.new("Frame")
    left.Parent = f
    left.Size = UDim2.new(0.2, 0, 0, 1)
    left.Position = UDim2.new(0, 0, 0.5, 0)
    left.BackgroundColor3 = COLOR_HEADER
    left.BorderSizePixel = 0

    local lbl = Instance.new("TextLabel")
    lbl.Parent = f
    lbl.AnchorPoint = Vector2.new(0.5, 0.5)
    lbl.Position = UDim2.new(0.5, 0, 0.5, 0)
    lbl.Size = UDim2.new(0.5, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.GothamBold
    lbl.Text = "——  " .. text .. "  ——"
    lbl.TextColor3 = COLOR_HEADER
    lbl.TextSize = 13
    lbl.TextScaled = false

    local right = Instance.new("Frame")
    right.Parent = f
    right.Size = UDim2.new(0.2, 0, 0, 1)
    right.Position = UDim2.new(0.8, 0, 0.5, 0)
    right.BackgroundColor3 = COLOR_HEADER
    right.BorderSizePixel = 0

    return f
end

-- Hàm tạo dòng text key: value
local LabelMap = {}
local function CreateRow(key, defaultVal, order, isSub)
    local f = Instance.new("Frame")
    f.Parent = ScrollFrame
    f.Size = UDim2.new(1, 0, 0, 20)
    f.BackgroundTransparency = 1
    f.LayoutOrder = order

    local lbl = Instance.new("TextLabel")
    lbl.Parent = f
    lbl.Size = UDim2.new(1, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.Gotham
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.TextSize = 13
    lbl.RichText = true
    lbl.Text = (isSub and "  <font color='#96ffb4'>• " .. key .. ":</font> " or "<font color='#c8c8c8'>" .. key .. ":</font> ") .. "<font color='#ffffff'>" .. defaultVal .. "</font>"
    lbl.TextColor3 = Color3.fromRGB(255, 255, 255)

    LabelMap[key] = {label = lbl, key = key, isSub = isSub}
    return f
end

-- Hàm cập nhật giá trị
local TweenService = game:GetService("TweenService")
local function SetValue(key, value)
    local entry = LabelMap[key]
    if not entry then return end
    local lbl = entry.label
    local newText = (entry.isSub and "  <font color='#96ffb4'>• " .. key .. ":</font> " or "<font color='#c8c8c8'>" .. key .. ":</font> ") .. "<font color='#ffffff'>" .. tostring(value) .. "</font>"
    if lbl.Text == newText then return end
    local t1 = TweenService:Create(lbl, TweenInfo.new(0.15), {TextTransparency = 1})
    t1:Play()
    t1.Completed:Wait()
    lbl.Text = newText
    local t2 = TweenService:Create(lbl, TweenInfo.new(0.15), {TextTransparency = 0})
    t2:Play()
end

