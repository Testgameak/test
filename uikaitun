-- ============================================
-- HÀM CẬP NHẬT GIÁ TRỊ
-- ============================================
local function SetValue(key, value)
    local entry = LabelMap[key]
    if not entry then return end
    local lbl     = entry.lbl
    local newText = entry.prefix .. "<font color='#ffffff'>" .. tostring(value) .. "</font>"
    if lbl.Text == newText then return end
    local t1 = TweenService:Create(lbl, TweenInfo.new(0.1), {TextTransparency = 1})
    t1:Play()
    t1.Completed:Wait()
    lbl.Text = newText
    TweenService:Create(lbl, TweenInfo.new(0.15), {TextTransparency = 0}):Play()
end

