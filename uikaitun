-- ============================================
-- LOGIC ĐẾM SEED TỪ KHO ĐỒ
-- ============================================
local function CountSeed(seedName)
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local char     = LocalPlayer.Character
    local count    = 0
    if backpack then
        for _, item in pairs(backpack:GetChildren()) do
            if item.Name == seedName then count += 1 end
        end
    end
    if char then
        for _, item in pairs(char:GetChildren()) do
            if item.Name == seedName then count += 1 end
        end
    end
    return count
end

local function UpdateAllSeeds()
    local total = 0
    for _, seedName in pairs(SEED_NAMES) do
        local n = CountSeed(seedName)
        total += n
        local key = SEED_DISPLAY[seedName]
        if key then SetValue(key, tostring(n)) end
    end
    SetValue("Seeds", total .. " total")
end

local function WatchContainer(container)
    if not container then return end
    container.ChildAdded:Connect(function(item)
        if SEED_DISPLAY[item.Name] then
            task.wait(0.05)
            UpdateAllSeeds()
        end
    end)
    container.ChildRemoved:Connect(function(item)
        if SEED_DISPLAY[item.Name] then
            task.wait(0.05)
            UpdateAllSeeds()
        end
    end)
end

local function WatchBackpack()
    WatchContainer(LocalPlayer:FindFirstChild("Backpack"))
end

LocalPlayer.CharacterAdded:Connect(function(char)
    WatchContainer(char)
    WatchBackpack()
    UpdateAllSeeds()
end)

WatchBackpack()
UpdateAllSeeds()

task.spawn(function()
    while true do
        task.wait(3)
        UpdateAllSeeds()
    end
end)

-- ============================================
-- TOGGLE PANEL (slide từ trái)
-- ============================================
local PanelOpen = false

local function TogglePanel()
    PanelOpen = not PanelOpen
    local targetX     = PanelOpen and 0 or -200
    local targetIcon  = PanelOpen and "✕" or "☰"
    local targetColor = PanelOpen
        and Color3.fromRGB(255, 80, 80)
        or  Color3.fromRGB(9, 255, 248)

    TweenService:Create(Panel,
        TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
        {Position = UDim2.new(0, targetX, 0, 0)}):Play()

    ToggleIcon.Text       = targetIcon
    ToggleIcon.TextColor3 = targetColor
    TweenService:Create(ToggleStroke,
        TweenInfo.new(0.2), {Color = targetColor}):Play()
end

ToggleButton.MouseButton1Click:Connect(TogglePanel)

