-- ==== BLUR SYSTEM ====
local BlurFrame = Instance.new('Frame')
BlurFrame.Parent = ScreenGui
BlurFrame.BackgroundColor3 = Color3.fromRGB(0,0,0)
BlurFrame.BackgroundTransparency = 1
BlurFrame.BorderSizePixel = 0
BlurFrame.Size = UDim2.new(1,0,1,0)
BlurFrame.ZIndex = 0

local BlurEffect = nil
local function SetBlur(intensity)
    intensity = math.clamp(intensity, 0, 0.95)
    local ts = game:GetService('TweenService')
    local ti = TweenInfo.new(0.3, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out)
    ts:Create(BlurFrame, ti, {BackgroundTransparency = 1 - intensity}):Play()
    if not BlurEffect then
        BlurEffect = Instance.new("BlurEffect")
        BlurEffect.Name = 'CustomBlur'
        BlurEffect.Parent = game.Lighting
    end
    ts:Create(BlurEffect, ti, {Size = intensity * 30}):Play()
end

-- ==== TOGGLE UI ====
local UIVisible = true
local AllElements = {TitleLabel, MainFrame}

local function ToggleUI(state)
    UIVisible = (state ~= nil) and state or (not UIVisible)
    local ts = game:GetService("TweenService")
    local ti = TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.InOut)

    if UIVisible then
        ToggleIcon.Text = "HIDE"
        for _, el in pairs(AllElements) do
            el.Visible = true
            ts:Create(el, ti, {BackgroundTransparency = el == TitleLabel and 1 or 0.2}):Play()
        end
        TitleLabel.TextTransparency = 1
        ts:Create(TitleLabel, ti, {TextTransparency = 0}):Play()
        SetBlur(0.3)
    else
        ToggleIcon.Text = "😶"
        ts:Create(TitleLabel, ti, {TextTransparency = 1}):Play()
        ts:Create(MainFrame, ti, {BackgroundTransparency = 1}):Play()
        task.delay(0.4, function()
            for _, el in pairs(AllElements) do el.Visible = false end
        end)
        SetBlur(0)
    end
end

